# Required
GEMINI_API_KEY=

# Assignment requirements
ALLOWED_FILENAMES=app.js,index.js

# Optional — Gemini
GEMINI_MODEL=gemini-2.5-flash

# Optional — Authentication (empty = disabled)
API_KEY=

# Optional — CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Optional — Rate limiting (requests/minute)
RATE_LIMIT_PER_MINUTE=60

# Optional — Upload retention (seconds, default 86400 = 24h)
UPLOAD_RETENTION_SECONDS=86400

# Optional — Qdrant storage path
QDRANT_PATH=qdrant_data

# Optional — SSL
SSL_ENABLED=false
SSL_CERTFILE=
SSL_KEYFILE=
